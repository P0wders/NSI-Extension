{
  "manifest_version": 3,
  "name": "Chocolatine Helper",
  "version": "1.1",

  "content_scripts": [
    {
      "matches": ["https://raisintine.fr/chocolatine/*"],
      "js": ["content.js"]
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["page.js"],
      "matches": ["https://raisintine.fr/chocolatine/*"]
    }
  ]
}
