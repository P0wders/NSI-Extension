{
  "manifest_version": 3,
  "name": "Chocolatine Helper",
  "version": "1.1",

  "icons": {
    "48": "icons/logo_48.png",
    "96": "icons/logo_96.png"
  },

  "content_scripts": [
    {
      "matches": ["https://raisintine.fr/chocolatine/*"],
      "js": ["content.js"]
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["page.js"],
      "matches": ["https://raisintine.fr/*"]
    }
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "chocolatine-helper@example.com"
    }
  }
}
